/* =====================================================================
   SQL SERVER COMPLIANCE & AUDIT - T-SQL SCRIPT TOOLKIT
/* =====================================================================

   1. PRIVILEGED SERVER-LEVEL ACCOUNTS 
   List members of sysadmin and other fixed server roles
===================================================================== */
SELECT
    r.name  AS server_role,
    m.name  AS member_name,
    m.type_desc,
    m.is_disabled,
    m.create_date,
    m.modify_date
FROM sys.server_role_members rm
JOIN sys.server_principals r ON rm.role_principal_id = r.principal_id
JOIN sys.server_principals m ON rm.member_principal_id = m.principal_id
ORDER BY r.name, m.name;

/* =====================================================================
   2. SERVER LOGINS - FULL INVENTORY w/ LAST LOGIN ACTIVITY
   Note: last_login requires login auditing / default trace or
   sys.dm_exec_sessions for currently/recently connected logins.
===================================================================== */
SELECT
    sp.name              AS login_name,
    sp.type_desc,
    sp.is_disabled,
    sp.create_date,
    sp.modify_date,
    sp.default_database_name,
    el.last_successful_login,
    el.last_login_attempt,
    el.failed_login_count
FROM sys.server_principals sp
LEFT JOIN sys.dm_exec_sessions s ON s.login_name = sp.name
OUTER APPLY (
    SELECT MAX(s2.login_time) AS last_successful_login,
           NULL AS last_login_attempt,
           NULL AS failed_login_count
    FROM sys.dm_exec_sessions s2
    WHERE s2.login_name = sp.name
) el
WHERE sp.type IN ('S','U','G')   -- SQL login, Windows user, Windows group
  AND sp.name NOT LIKE '##%'
ORDER BY sp.name;

-- Alternative: orphaned / never-connected logins (no active session, old create date)
SELECT name, type_desc, create_date, modify_date, is_disabled
FROM sys.server_principals
WHERE type IN ('S','U')
  AND name NOT IN (SELECT login_name FROM sys.dm_exec_sessions WHERE login_name IS NOT NULL)
  AND name NOT LIKE '##%'
ORDER BY create_date;

/* ==========================================================
3. ORPHANED DATABASE USERS 
  DATABASE USERS vs SERVER LOGINS REPORT
   Shows orphaned and mapped users across all databases
========================================================== */

IF OBJECT_ID('tempdb..#DBUsers') IS NOT NULL
    DROP TABLE #DBUsers;

CREATE TABLE #DBUsers
(
    database_name      SYSNAME,
    user_name          SYSNAME,
    user_type          NVARCHAR(60),
    user_sid           VARBINARY(85),
    login_name         SYSNAME NULL,
    login_sid          VARBINARY(85) NULL,
    access_status      VARCHAR(20)
);

DECLARE @sql NVARCHAR(MAX) = N'';

SELECT @sql = @sql + '
USE ' + QUOTENAME(name) + ';

INSERT INTO #DBUsers
(
    database_name,
    user_name,
    user_type,
    user_sid,
    login_name,
    login_sid,
    access_status
)
SELECT
    DB_NAME()                                   AS database_name,
    dp.name                                     AS user_name,
    dp.type_desc                                AS user_type,
    dp.sid                                      AS user_sid,
    sp.name                                     AS login_name,
    sp.sid                                      AS login_sid,
    CASE
        WHEN sp.sid IS NULL THEN ''ORPHANED''
        ELSE ''MAPPED''
    END                                         AS access_status
FROM sys.database_principals dp
LEFT JOIN master.sys.server_principals sp
       ON dp.sid = sp.sid
WHERE dp.type IN (''S'',''U'',''G'')
  AND dp.principal_id > 4
  AND dp.name NOT IN (''dbo'',''guest'',''INFORMATION_SCHEMA'',''sys'');
'
FROM sys.databases
WHERE state_desc = 'ONLINE'
  AND database_id > 4; -- Exclude system DBs

EXEC sp_executesql @sql;

SELECT
    database_name,
    user_name,
    user_type,
    login_name,
    access_status,
    CONVERT(VARCHAR(200), user_sid, 1)  AS user_sid_hex,
    CONVERT(VARCHAR(200), login_sid, 1) AS login_sid_hex
FROM #DBUsers
ORDER BY
    database_name,
    user_name;
DROP TABLE #DBUsers;

========================================================================================
Audit Review Interpretation
========================================================================================
Access Status	            Meaning
========================================================================================
MAPPED	                  Database user is correctly linked to a server login
ORPHANED	                Database user exists but no matching server login SID exists
login_name NULL	          No corresponding login found on the instance
========================================================================================


/* =====================================================================
   4. EXPLICIT PERMISSION GRANTS
   Direct (non-role) permission grants per database
===================================================================== */
/* ==========================================================
   DATABASE ROLE MEMBERSHIP AUDIT REPORT
   (db_owner, db_securityadmin, db_accessadmin, db_ddladmin)
========================================================== */

IF OBJECT_ID('tempdb..#DBRoleMembers') IS NOT NULL
    DROP TABLE #DBRoleMembers;

CREATE TABLE #DBRoleMembers
(
    database_name   SYSNAME,
    db_role         SYSNAME,
    member_name     SYSNAME,
    member_type     NVARCHAR(60),
    login_name      SYSNAME NULL,
    login_type      NVARCHAR(60) NULL,
    access_status   VARCHAR(20)
);

DECLARE @SQL NVARCHAR(MAX) = N'';

SELECT @SQL += '
USE ' + QUOTENAME(name) + ';

INSERT INTO #DBRoleMembers
(
    database_name,
    db_role,
    member_name,
    member_type,
    login_name,
    login_type,
    access_status
)
SELECT
    DB_NAME(),
    r.name,
    m.name,
    m.type_desc,
    sp.name,
    sp.type_desc,
    CASE
        WHEN sp.sid IS NULL
             AND m.type IN (''S'',''U'',''G'')
        THEN ''ORPHANED''
        ELSE ''MAPPED''
    END
FROM sys.database_role_members rm
INNER JOIN sys.database_principals r
    ON rm.role_principal_id = r.principal_id
INNER JOIN sys.database_principals m
    ON rm.member_principal_id = m.principal_id
LEFT JOIN master.sys.server_principals sp
    ON m.sid = sp.sid
WHERE r.name IN
(
    ''db_owner'',
    ''db_securityadmin'',
    ''db_accessadmin'',
    ''db_ddladmin''
);
'
FROM sys.databases
WHERE database_id > 4
  AND state_desc = 'ONLINE';

EXEC sp_executesql @SQL;

SELECT
    database_name,
    db_role,
    member_name,
    member_type,
    login_name,
    login_type,
    access_status
FROM #DBRoleMembers
ORDER BY
    database_name,
    db_role,
    member_name;

DROP TABLE #DBRoleMembers;

/* =====================================================================
  5. SERVER-LEVEL PERMISSIONS / HIGH-RISK GRANTS
===================================================================== */
/* ==========================================================
   PRIVILEGED DATABASE ACCESS REVIEW REPORT
   SOX / Audit / Compliance Evidence
========================================================== */

IF OBJECT_ID('tempdb..#PrivilegedAccessReview') IS NOT NULL
    DROP TABLE #PrivilegedAccessReview;

CREATE TABLE #PrivilegedAccessReview
(
    server_name        SYSNAME,
    database_name      SYSNAME,
    db_role            SYSNAME,
    member_name        SYSNAME,
    member_type        NVARCHAR(60),
    login_name         SYSNAME NULL,
    login_type         NVARCHAR(60) NULL,
    access_status      VARCHAR(20),
    risk_level         VARCHAR(20),
    review_status      VARCHAR(50),
    review_date        DATETIME
);

DECLARE @SQL NVARCHAR(MAX) = N'';

SELECT @SQL += '
USE ' + QUOTENAME(name) + ';

INSERT INTO #PrivilegedAccessReview
(
    server_name,
    database_name,
    db_role,
    member_name,
    member_type,
    login_name,
    login_type,
    access_status,
    risk_level,
    review_status,
    review_date
)
SELECT
    @@SERVERNAME,
    DB_NAME(),
    r.name,
    m.name,
    m.type_desc,
    sp.name,
    sp.type_desc,

    CASE
        WHEN sp.sid IS NULL
             AND m.type IN (''S'',''U'',''G'')
        THEN ''ORPHANED''
        ELSE ''MAPPED''
    END,

    CASE
        WHEN r.name = ''db_owner''
            THEN ''CRITICAL''
        WHEN r.name IN (''db_securityadmin'',''db_accessadmin'')
            THEN ''HIGH''
        WHEN r.name = ''db_ddladmin''
            THEN ''MEDIUM''
        ELSE ''LOW''
    END,

    ''PENDING REVIEW'',
    GETDATE()

FROM sys.database_role_members rm
JOIN sys.database_principals r
    ON rm.role_principal_id = r.principal_id
JOIN sys.database_principals m
    ON rm.member_principal_id = m.principal_id
LEFT JOIN master.sys.server_principals sp
    ON m.sid = sp.sid

WHERE r.name IN
(
    ''db_owner'',
    ''db_securityadmin'',
    ''db_accessadmin'',
    ''db_ddladmin''
);
'
FROM sys.databases
WHERE database_id > 4
  AND state_desc = 'ONLINE';

EXEC sp_executesql @SQL;

SELECT
    server_name,
    database_name,
    db_role,
    member_name,
    member_type,
    login_name,
    login_type,
    access_status,
    risk_level,
    review_status,
    review_date
FROM #PrivilegedAccessReview
ORDER BY
    CASE risk_level
        WHEN 'CRITICAL' THEN 1
        WHEN 'HIGH' THEN 2
        WHEN 'MEDIUM' THEN 3
        ELSE 4
    END,
    database_name,
    db_role,
    member_name;

/* =====================================================================
  6. LOGIN/PASSWORD POLICY CHECK FOR SQL LOGINS
===================================================================== */
SELECT
    name AS login_name,
    is_disabled,
    is_policy_checked,
    is_expiration_checked,
    create_date,
    modify_date
FROM sys.sql_logins
ORDER BY is_policy_checked, is_expiration_checked;

